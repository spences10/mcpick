		"@changesets/cli": "^2.31.0",
		"@types/node": "^25.6.0",
		"vite-plus": "^0.1.19",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@10.33.2"
